# Open WebUI — homelab environment variables
# Copy this file to .env and fill in your values.

# API key for your preferred OpenAI-compatible provider (OpenAI, Anthropic via proxy, etc.)
OPENAI_API_KEY=

# Base URL for Ollama. Adjust if Ollama runs on a different host/port.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Set to 1 in air-gapped environments to block Hugging Face model downloads.
HF_HUB_OFFLINE=0
